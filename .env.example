# ── Deployment mode ──────────────────────────────────────────────────────────
# "local"  → plain httpx, direct API connections (Anthropic, Voyage AI, etc.)
# "deploy" → httpx http2=True, routes through LiteLLM proxy on your server
# "ollama" → plain httpx, local Ollama instance at OLLAMA_BASE_URL
ENV_MODE=ollama

# ── Ollama (used when ENV_MODE=ollama) ────────────────────────────────────────
# Ollama exposes an OpenAI-compatible API at /v1 — no API key needed
OLLAMA_BASE_URL=http://localhost:11434
# Change these to match the models you have pulled locally:
#   ollama list   ← shows your available models
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=qwen3-embedding:4b
LLM_TEMPERATURE=0.0
LLM_API_KEY=sk-.....
EMBEDDING_BASE_URL=https://api.voyageai.com/v1
EMBEDDING_API_KEY=pa-...
ENDPOINT_BATCH_SIZE=5

# ── FAISS ────────────────────────────────────────────────────────────────────
FAISS_INDEX_PATH=data/faiss_index
CHUNK_SIZE=1024
CHUNK_OVERLAP=128
RETRIEVER_TOP_K=8

# ── File storage ─────────────────────────────────────────────────────────────
UPLOAD_DIR=data/uploads
# GENERATED_TESTS_DIR=generated_tests
# ALLURE_RESULTS_DIR=allure-results
